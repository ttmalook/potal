# =====================================================================
# Frontend (Vite) 설정 — 이 파일을 .env 로 복사해 사용
# 주의: 여기에는 SecurityScorecard API Token을 절대 넣지 마세요.
#       토큰은 backend/.env 에서만 관리됩니다.
# =====================================================================

# SSC Risk Import 동작 모드: mock | backend
#  - mock    : 기존 mock progress (기본값)
#  - backend : 우리 Backend(/api/ssc/import-risk)를 호출해 실제 SSC API read-only import
VITE_SSC_API_MODE=mock

# Backend 주소 (비워두면 Vite dev proxy로 /api 가 백엔드에 연결됨)
# 예: http://localhost:8787
VITE_BACKEND_URL=

# 개발자용 Mock UI 노출 여부: false | true (기본값 false)
#  - false: 사용자 화면에 Mock Mode / Mock Sample / Mock fallback 미노출.
#           API/Backend 실패 시 Mock 자동 대체 없이 오류 상태만 표시.
#  - true : Developer Mock Samples 및 수동 "Mock 데이터로 보기" 버튼 표시(개발/회귀 테스트용).
#  - Mock 데이터 파일은 삭제하지 않고 dev-only fixture로 보존.
VITE_ENABLE_DEV_MOCKS=false
