# VM-APP — 앱 + 웹 티어
# 사용: cp .env.app.example .env && vi .env

# ── VM-DB 연결 ──
PGHOST=10.0.0.11            # VM-DB 의 IP
PGPORT=5432
PGDATABASE=ssc_portal
PGUSER=ssc
PGPASSWORD=replace_with_strong_db_password   # VM-DB 와 동일 값
PGSSL=true
PGSSL_REJECT_UNAUTHORIZED=false              # 사설 CA/자체서명이면 false

# ── VM-LAB 연결 ──
LAB_COLLECTOR=docker
LAB_COLLECTOR_URL=http://10.0.0.12:8899      # VM-LAB 의 IP

# ── 인증 시크릿 (기본값이면 부팅 거부) ──
# openssl rand -base64 48
AUTH_ACCESS_SECRET=replace_with_strong_random_secret
SEED_ADMIN_EMAIL=admin@ssc.local
# openssl rand -base64 24
SEED_ADMIN_PASSWORD=replace_with_strong_password

# ── 웹 / TLS ──
SERVER_NAME=10.0.0.10                        # VM-APP 의 IP 또는 사내 호스트명
CORS_ORIGIN=https://10.0.0.10
ENABLE_HSTS=false                            # 자체서명 구간은 false 유지
HSTS_MAX_AGE=300

# ── SecurityScorecard (선택) ──
SSC_API_BASE_URL=https://api.securityscorecard.io
SSC_API_TOKEN=

# ── 로컬 LLM (선택) ──
OLLAMA_MODEL=exaone3.5:2.4b
OLLAMA_TIMEOUT_MS=90000
