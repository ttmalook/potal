# =====================================================================
# docker-compose.yml 용 환경변수 — 이 파일을 .env.docker 로 복사 후 값 채우기
#   docker compose --env-file .env.docker up -d --build
# 주의: .env.docker 는 .gitignore(.env.*)로 커밋 차단됩니다. 실제 시크릿 커밋 금지.
# =====================================================================

# ── PostgreSQL ──
PGDATABASE=ssc_portal
PGUSER=ssc
# 강한 비밀번호로 교체
PGPASSWORD=change_me_db_password
# 컨테이너 내부 통신은 사설 네트워크라 기본 off. 외부 관리형 DB(TLS)면 true.
PGSSL=false

# ── 인증 (기본값/미설정이면 서버 부팅 거부: assertAuthConfig) ──
# 생성: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
AUTH_ACCESS_SECRET=replace_with_strong_random_secret
SEED_ADMIN_EMAIL=admin@ssc.local
SEED_ADMIN_PASSWORD=replace_with_strong_password

# ── 웹/오리진 ──
# 접속 도메인(자체서명 인증서 CN/SAN 에 사용). 도메인 구매 전엔 localhost.
SERVER_NAME=localhost
# 동일 오리진이면 미사용. 필요 시 접속 오리진과 정확히 일치시키세요.
CORS_ORIGIN=https://localhost

# ── HSTS (전환 순서 준수) ──
# 스테이징/자체서명 구간: false 로 유지.
# 실도메인+실인증서로 HTTPS 정상 확인 후: true + 짧게(300) → 이후 단계적으로 길게.
ENABLE_HSTS=false
HSTS_MAX_AGE=300

# ── SecurityScorecard 연동 (선택) ──
SSC_API_BASE_URL=https://api.securityscorecard.io
SSC_API_TOKEN=

# ── 조치 가이드 "해석" 생성 (로컬 Ollama · 데이터 외부 유출 없음) ──
# 모델 변경 시 여기서 지정 → compose ollama 서비스가 자동 pull. 기본 exaone3.5:2.4b.
OLLAMA_MODEL=exaone3.5:2.4b
# OLLAMA_TIMEOUT_MS=90000
