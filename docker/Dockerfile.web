# =====================================================================
# SSC Partner Portal — Web (nginx: TLS 종단 + SPA 정적 + /api 프록시)
#   build context: .  (claude/)
#   1) build 스테이지: Vite 로 SPA(dist) 빌드
#   2) nginx 스테이지: dist 서빙 + /docker-entrypoint.d 로 자체서명 인증서·HSTS 준비
# =====================================================================
FROM node:24-alpine AS build
WORKDIR /app
COPY package.json package-lock.json ./
RUN npm ci
COPY . .
RUN npm run build

FROM nginx:1.27-alpine
# 자체서명 인증서 생성용 (도메인 구매 후 실인증서로 교체하면 미사용)
RUN apk add --no-cache openssl

COPY --from=build /app/dist /usr/share/nginx/html
COPY docker/nginx/default.conf /etc/nginx/conf.d/default.conf
# 공식 nginx 엔트리포인트가 /docker-entrypoint.d/*.sh 를 nginx 기동 전에 실행
COPY docker/nginx/40-ssc-tls.sh /docker-entrypoint.d/40-ssc-tls.sh
RUN chmod +x /docker-entrypoint.d/40-ssc-tls.sh

EXPOSE 80 443
