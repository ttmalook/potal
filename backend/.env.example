# =====================================================================
# SecurityScorecard API — Backend 전용 설정
# 실제 토큰을 이 파일이나 git에 절대 커밋하지 마세요.
# 사용 시 이 파일을 backend/.env 로 복사한 뒤 값을 채우세요.
# (.env, .env.* 는 .gitignore에서 차단됩니다)
# =====================================================================

# --- SecurityScorecard 연동 (신규 표준 이름) ---
SSC_API_BASE_URL=https://api.securityscorecard.io
SSC_API_TOKEN=replace_with_real_token

# 연동 검증(Probe)용 테스트 파라미터
SSC_TEST_DOMAIN=example.com
SSC_TEST_PORTFOLIO_ID=

# 쓰기/삭제 테스트 보호 스위치 (기본 false)
#  - SSC_ENABLE_WRITE_TESTS=true 이고 호출부에서 dryRun:false 일 때만 POST/PUT/PATCH 실제 호출
#  - DELETE는 이 값과 무관하게 이번 단계에서 절대 실제 실행하지 않음(항상 시뮬레이션)
SSC_ENABLE_WRITE_TESTS=false
SSC_ENABLE_DELETE_TESTS=false

# --- 구 이름 (하위 호환: 위 신규 이름이 없으면 아래를 사용) ---
# SECURITYSCORECARD_API_BASE_URL=https://api.securityscorecard.io
# SECURITYSCORECARD_API_TOKEN=replace-with-real-token

# --- 서버 ---
PORT=8787
CORS_ORIGIN=http://localhost:5173

# --- PostgreSQL (lab/docker-compose.yml 의 postgres) ---
# 미설정 시 아래 기본값 사용. 연결 실패하면 자동으로 파일 저장소로 폴백.
PGHOST=localhost
PGPORT=5432
PGDATABASE=ssc_portal
PGUSER=ssc
PGPASSWORD=ssc_dev_pw
# 또는 DATABASE_URL=postgres://ssc:ssc_dev_pw@localhost:5432/ssc_portal

# --- DB TLS(전송 중 암호화) — 배포 권장 ---
# PGSSL=true 로 활성(로컬은 off). 사설/자체서명 CA면 아래를 false
PGSSL=false
# PGSSL_REJECT_UNAUTHORIZED=true

# --- 인증 (배포 전 반드시 설정) ---
# NODE_ENV=production 이고 아래가 기본값/미설정이면 서버 부팅을 거부합니다.
# AUTH_ACCESS_SECRET: JWT 서명 키 — 강한 랜덤값.
#   생성 예) node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
AUTH_ACCESS_SECRET=replace_with_strong_random_secret
# 기본 관리자 시드 — 프로덕션 기본 비번 금지
SEED_ADMIN_EMAIL=admin@ssc.local
SEED_ADMIN_PASSWORD=replace_with_strong_password

# --- Validation Sandbox 수집기 ---
# LAB_COLLECTOR=simulated | docker
# LAB_COLLECTOR_URL=http://localhost:8899

# --- 조치 가이드 "해석"(쉬운말) 생성 — 로컬 Ollama (데이터 외부 유출 없음) ---
# 미설정 시 로컬 기본값 사용. 도커 배포 시 OLLAMA_URL=http://ollama:11434
# OLLAMA_URL=http://localhost:11434
# OLLAMA_MODEL=exaone3.5:2.4b
# OLLAMA_TIMEOUT_MS=90000

# --- SSC AI Lab Builder (신규 랩 레시피 컴파일) — Claude API ---
# 키는 .env 또는 관리자 화면(암호화 저장)에서 설정. 관리자 설정이 .env 보다 우선.
# CLAUDE_MODEL 은 실제 접근 가능한 Anthropic 모델 ID 로 지정(미설정 시 기본값 사용).
# ANTHROPIC_API_KEY=sk-ant-...
# CLAUDE_MODEL=claude-opus-4-8
# CLAUDE_TIMEOUT_MS=60000
# CLAUDE_MAX_TOKENS=4096
